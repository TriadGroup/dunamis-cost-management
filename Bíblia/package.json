  "private": true,
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('.next', { recursive: true, force: true })\"",
    "dev": "next dev",
    "build": "npm run clean && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "import:bibles": "tsx scripts/import-bibles.ts --mode=skip",
